#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
PHOENIX_PID=""
REDWOOD_PID=""

cleanup() {
  echo ""
  echo "Shutting down..."
  [[ -n "$REDWOOD_PID" ]] && kill "$REDWOOD_PID" 2>/dev/null
  [[ -n "$PHOENIX_PID" ]] && kill "$PHOENIX_PID" 2>/dev/null
  wait 2>/dev/null
  echo "Done."
}
trap cleanup EXIT INT TERM

# Colors
CYAN='\033[0;36m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
NC='\033[0m'

# Free ports if occupied by stale processes
free_port() {
  local port=$1
  local pid
  pid=$(lsof -ti :"$port" 2>/dev/null || true)
  if [[ -n "$pid" ]]; then
    echo -e "${RED}[dev]${NC} Port $port in use (pid $pid) — killing"
    kill $pid 2>/dev/null || true
    sleep 0.5
  fi
}

free_port 4000
free_port 8910

# Load env vars. The authoritative file is `.env.local` at the repo root —
# it holds GITHUB_CLIENT_ID, GITHUB_CLIENT_SECRET, GITHUB_ALLOWLIST, plus
# every API key both Phoenix and Redwood read at runtime. `phoenix/.env.local`
# is a historical subset kept around for backwards-compat; if it exists we
# also source it, but the root file wins because it's loaded first and any
# overlapping keys get re-exported by the phoenix file.
if [[ -f "$ROOT/.env.local" ]]; then
  set -a
  # shellcheck disable=SC1091
  source "$ROOT/.env.local"
  set +a
else
  echo -e "${RED}[dev]${NC} Missing $ROOT/.env.local"
  echo -e "${RED}[dev]${NC} Phoenix needs GITHUB_CLIENT_ID / GITHUB_CLIENT_SECRET / GITHUB_ALLOWLIST to boot."
  exit 1
fi

if [[ -f "$ROOT/phoenix/.env.local" ]]; then
  set -a
  # shellcheck disable=SC1091
  source "$ROOT/phoenix/.env.local"
  set +a
fi

# Fail fast with an actionable message BEFORE Phoenix crashes on its own
# (runtime.exs:36 raises, but the script should surface the gap first so
# the user doesn't have to read a Phoenix traceback to understand).
if [[ -z "${GITHUB_CLIENT_ID:-}" || -z "${GITHUB_CLIENT_SECRET:-}" ]]; then
  echo -e "${RED}[dev]${NC} GITHUB_CLIENT_ID / GITHUB_CLIENT_SECRET still empty after sourcing envs."
  echo -e "${RED}[dev]${NC} Check $ROOT/.env.local — make sure both are set and uncommented."
  exit 1
fi

if [[ -z "${GITHUB_ALLOWLIST:-}" ]]; then
  echo -e "${YELLOW}[dev]${NC} GITHUB_ALLOWLIST is empty — OAuth will come back as forbidden for every user."
fi

echo -e "${CYAN}[phoenix]${NC} Starting on :4000"
echo -e "${YELLOW}[redwood]${NC} Starting on :8910"
echo ""

# Phoenix backend
(cd "$ROOT/phoenix" && mix phx.server 2>&1 | while IFS= read -r line; do
  echo -e "${CYAN}[phoenix]${NC} $line"
done) &
PHOENIX_PID=$!

# RedwoodJS frontend
(cd "$ROOT/redwood" && yarn rw dev web 2>&1 | while IFS= read -r line; do
  echo -e "${YELLOW}[redwood]${NC} $line"
done) &
REDWOOD_PID=$!

wait
